# LUMINARA environment variables (sample — copy to .env.local)
# All values are intentionally left blank. The site renders without any of these.

# Open Graph image (absolute URL). If unset, /og.png is used.
NEXT_PUBLIC_OG_IMAGE=

# Plausible / Fathom analytics domain. If unset, no analytics script is loaded.
NEXT_PUBLIC_ANALYTICS_DOMAIN=
